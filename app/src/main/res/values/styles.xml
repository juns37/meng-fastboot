<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MengFastbootno" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:fontFamily">@font/roboto_mono</item>
    </style>
    <style name="Widget.MengFastboot.MaterialButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:padding">12dp</item>
        <item name="backgroundTint">@color/teal_700</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="Widget.MengFastboot.MaterialButton.Warn" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:padding">12dp</item>
        <item name="backgroundTint">@color/orange_700</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="Widget.MengFastboot.MaterialButton.Danger" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:padding">12dp</item>
        <item name="backgroundTint">@color/red_500</item>
        <item name="android:textColor">@color/white</item>
    </style>
</resources>